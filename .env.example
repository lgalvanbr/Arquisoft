# ======================== CONFIGURACIÓN COMPARTIDA ========================
DEBUG=False
ALLOWED_HOSTS=*

# ======================== BASE DE DATOS ========================
# PostgreSQL - Autenticación
AUTH_DB_ENGINE=django.db.backends.postgresql
AUTH_DB_NAME=autenticacion_db
AUTH_DB_USER=postgres
AUTH_DB_PASSWORD=postgres
AUTH_DB_HOST=localhost
AUTH_DB_PORT=5432

# PostgreSQL - Reportes
REPORTES_DB_ENGINE=django.db.backends.postgresql
REPORTES_DB_NAME=reportes_db
REPORTES_DB_USER=postgres
REPORTES_DB_PASSWORD=postgres
REPORTES_DB_HOST=localhost
REPORTES_DB_PORT=5432

# ======================== SEGURIDAD ========================
SECRET_KEY_AUTH=django-insecure-your-secret-key-here-auth
SECRET_KEY_REPORTES=django-insecure-your-secret-key-here-reportes
JWT_SECRET_KEY=your-jwt-secret-key-here

# ======================== JWT CONFIGURATION ========================
JWT_ACCESS_TOKEN_LIFETIME=3600  # 1 hora en segundos
JWT_REFRESH_TOKEN_LIFETIME=86400  # 1 día en segundos

# ======================== CORS ========================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8001

# ======================== AWS ========================
AWS_ENABLED=True
AWS_ACCESS_KEY_ID=your-aws-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_DEFAULT_REGION=us-east-1

# ======================== GCP ========================
GCP_ENABLED=True
GCP_PROJECT_ID=your-gcp-project-id
GCP_CREDENTIALS_PATH=/path/to/credentials.json

# ======================== EMAIL (para notificaciones) ========================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# ======================== LOGGING ========================
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/

# ======================== ASR CONFIGURATION ========================
MAX_USUARIOS_CONCURRENTES=5000
PICO_USUARIOS_CONCURRENTES=12000
DISPONIBILIDAD_MINIMA=0.95
REPORTE_MENSUAL_MAX_MS=100
ANALISIS_BACKGROUND_UMBRAL_MS=2000

# ======================== SEGURIDAD ASR ========================
MAX_INTENTOS_LOGIN=5
VENTANA_TIEMPO_INTENTOS_SEGUNDOS=600
DURACION_BLOQUEO_SEGUNDOS=300
TIEMPO_DETECCION_ANOMALIAS_MS=2000

# ======================== DESARROLLO ========================
DEVELOPMENT_MODE=False
ALLOW_LOCALHOST_CORS=True
